{
  // Minimal worker config for the vitest-pool-workers (real workerd) rate-limit suite. It carries ONLY
  // the four `ratelimit` unsafe bindings from wrangler.jsonc — miniflare emulates them for real — so the
  // .data twin fix can be proven against the actual runtime limiter without pulling in the D1 / R2 / AI /
  // Vectorize bindings or the React Router `main` bundle (which the limiter tests never invoke).
  // namespace_id / limits mirror wrangler.jsonc so the emulated thresholds match production.
  "name": "sigma-ratelimit-test",
  "compatibility_date": "2025-04-04",
  "unsafe": {
    "bindings": [
      {
        "name": "CSV_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1001",
        "simple": { "limit": 10, "period": 60 },
      },
      {
        "name": "AGG_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1002",
        "simple": { "limit": 30, "period": 60 },
      },
      {
        "name": "SEARCH_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1003",
        "simple": { "limit": 20, "period": 60 },
      },
      {
        "name": "ASSISTANT_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1005",
        "simple": { "limit": 10, "period": 60 },
      },
    ],
  },
}
