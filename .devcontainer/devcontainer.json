{
  "name": "sigma-prototype",
  "build": {
    "dockerfile": "Dockerfile"
  },
  // Relax the default Docker seccomp/apparmor profiles so Codex's bundled
  // bubblewrap (bwrap) can create the user namespace its sandbox needs.
  // Without this, `unshare(CLONE_NEWUSER)` is blocked and codex-workers fail
  // with "bwrap: No permissions to create a new namespace".
  "runArgs": [
    "--security-opt", "seccomp=unconfined",
    "--security-opt", "apparmor=unconfined"
  ],
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "remoteUser": "node",
  "workspaceFolder": "/workspaces/sigma-prototype",
  "forwardPorts": [5173, 8789],
  "portsAttributes": {
    "5173": { "label": "web (React Router dev)" },
    "8789": { "label": "etl (wrangler dev)" }
  },
  "otherPortsAttributes": { "onAutoForward": "notify" },
  "mounts": [
    "source=sigma-prototype-node-modules,target=/workspaces/sigma-prototype/node_modules,type=volume",
    "source=sigma-prototype-pnpm-store,target=/home/node/.pnpm-store,type=volume",
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind"
  ],
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "LOCAL_WORKSPACE_FOLDER": "${localWorkspaceFolder}"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "EditorConfig.EditorConfig",
        "redhat.vscode-yaml",
        "qwtel.sqlite-viewer",
        "cloudflare.vscode-cloudflare-workers",
        "anthropic.claude-code",
        "github.vscode-github-actions",
        "sanjulaganepola.github-local-actions",
        "bierner.markdown-mermaid",
        "mechatroner.rainbow-csv"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  }
}
